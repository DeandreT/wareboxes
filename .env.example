# Database (Postgres-only).
# Local default matches docker-compose.yml.
DATABASE_URL=postgres://wareboxes:wareboxes@127.0.0.1:5433/wareboxes

BIND_ADDR=127.0.0.1:8080

# Optional: created on first startup if the user does not yet exist, and
# granted the `admin` permission via its per-user self role.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-please

RUST_LOG=info,wareboxes_server=debug
